# ==================== 数据库配置 ====================
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_PORT=5432

# ==================== Nacos配置 ====================
NACOS_PORT=8848

# ==================== MinIO配置 ====================
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=your_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OSS_BUCKET=agenthub-articles

# ==================== LLM配置 ====================
LLM_PROVIDER=mock
LLM_API_KEY=your_api_key
LLM_API_URL=

# ==================== 应用配置 ====================
APP_PORT=8080
WEB_PORT=80
MACHINE_ID=1
JAVA_OPTS=-Xms256m -Xmx512m