<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.agenthub.infrastructure.mapper.AgentMapper">

    <resultMap id="BaseResultMap" type="com.agenthub.infrastructure.entity.AgentPO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="endpoint" column="endpoint"/>
        <result property="version" column="version"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, endpoint, version, type, status, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.agenthub.infrastructure.entity.AgentPO">
        INSERT INTO agents (id, name, description, endpoint, version, type, status, created_at, updated_at)
        VALUES (#{id}, #{name}, #{description}, #{endpoint}, #{version}, #{type}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.agenthub.infrastructure.entity.AgentPO">
        UPDATE agents
        SET name = #{name},
            description = #{description},
            endpoint = #{endpoint},
            version = #{version},
            type = #{type},
            status = #{status},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM agents WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agents
        WHERE id = #{id}
    </select>

    <select id="selectByName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agents
        WHERE name = #{name}
    </select>

    <select id="selectByNameLike" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agents
        WHERE name LIKE CONCAT('%', #{name}, '%')
        ORDER BY created_at DESC
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agents
        WHERE status = #{status}
        ORDER BY created_at DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM agents
        ORDER BY created_at DESC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM agents
    </select>

    <select id="countByStatus" resultType="long">
        SELECT COUNT(*) FROM agents WHERE status = #{status}
    </select>

</mapper>